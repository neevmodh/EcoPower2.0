# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eaas_platform?retryWrites=true&w=majority

# ─── Groq AI ──────────────────────────────────────────────────────────────────
# Get from https://console.groq.com/keys
# Used server-side (Express routes) — never exposed to browser
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: expose to browser for direct fallback (less secure)
# NEXT_PUBLIC_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
